    </article>`).join('');

  function step() {
    const first = track.firstElementChild;
    return first ? first.getBoundingClientRect().width + parseFloat(getComputedStyle(track).gap || 0) : 0;
  }
  function updateBtn() {
    nextBtn.disabled = track.scrollLeft >= track.scrollWidth - track.clientWidth - 2;
  }
  nextBtn.addEventListener('click', () => { track.scrollBy({ left: step(), behavior: 'smooth' }); setTimeout(updateBtn, 260); });
  track.addEventListener('scroll', () => requestAnimationFrame(updateBtn));
  window.addEventListener('resize', updateBtn);
  updateBtn();
})();
</script>
