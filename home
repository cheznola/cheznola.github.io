<style>
/* ────────────────────────────────────────────
   RESET & TOKENS
──────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --cream:      #F4EFE4;
  --cream-2:    #EDE7D9;
  --cream-3:    #E5DDD0;
  --parchment:  #F9F5EE;
  --sage:       #6E7E64;
  --sage-bg:    #5D6E54;
  --sage-pale:  #EBF0E7;
  --brown:      #C87542;
  --brown-deep: #A85E2E;
  --brown-pale: #F3E8D8;
  --dark:       #1E1A15;
  --dark-2:     #2C2720;
  --dark-3:     #3D3830;
  --ink:        #3A342C;
  --muted:      #7A7168;
  --muted-lt:   #A09890;
  --border:     rgba(58,52,44,.10);
  --border-2:   rgba(58,52,44,.16);
  --playpen:    'Playpen Sans', cursive;
  --serif:      'Instrument Serif', Georgia, serif;
  --sans:       'Inter', system-ui, sans-serif;
}

html { scroll-behavior: smooth; }

body {
  background: var(--parchment);
  color: var(--ink);
  font-family: var(--sans);
  font-size: 15px;
  line-height: 1.65;
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
}

/* ────────────────────────────────────────────
   ANIMATIONS
──────────────────────────────────────────── */
@keyframes fadeUp {
  from { opacity:0; transform:translateY(20px); }
  to   { opacity:1; transform:translateY(0); }
}
@keyframes pulse-dot {
  0%,100% { opacity:1; transform:scale(1); }
  50%      { opacity:.4; transform:scale(.78); }
}
@keyframes ticker {
  0%   { transform:translateX(0); }
  100% { transform:translateX(-50%); }
}

.fu { opacity:0; animation:fadeUp .65s ease forwards; }
.d1{animation-delay:.05s}.d2{animation-delay:.15s}.d3{animation-delay:.25s}
.d4{animation-delay:.35s}.d5{animation-delay:.45s}

/* ────────────────────────────────────────────
   NAV
──────────────────────────────────────────── */
nav {
  position:fixed; top:0; left:0; right:0; z-index:200;
  height:58px;
  display:flex; align-items:center; justify-content:space-between;
  padding:0 40px;
  background:rgba(249,245,238,.93);
  backdrop-filter:blur(16px);
  border-bottom:1px solid var(--border);
}
.nav-logo {
  font-family: var(--playpen);
  font-weight: 700; font-size: 22px;
  color: var(--brown); text-decoration: none;
}
.nav-links { display:flex; gap:28px; list-style:none; }
.nav-links a {
  font-size:13px; font-weight:400; color:var(--muted);
  text-decoration:none; transition:color .15s;
}
.nav-links a:hover { color:var(--ink); }
.nav-cta {
  font-size:13px; font-weight:700;
  color:var(--parchment); background:var(--dark);
  border:none; border-radius:6px;
  padding:8px 20px; text-decoration:none;
  transition:background .15s, transform .12s; white-space:nowrap;
}
.nav-cta:hover { background:var(--dark-2); transform:translateY(-1px); }

/* ────────────────────────────────────────────
   HERO
──────────────────────────────────────────── */
.hero {
  padding:130px 24px 88px;
  max-width:780px; margin:0 auto; text-align:center;
}
.hero-badge {
  display:inline-flex; align-items:center; gap:8px;
  background:var(--brown-pale); border:1px solid rgba(200,117,66,.28);
  border-radius:100px; padding:5px 16px; margin-bottom:28px;
  font-size:12px; font-weight:700; color:var(--brown-deep);
  letter-spacing:.07em; text-transform:uppercase;
}
.ldot {
  width:6px; height:6px; border-radius:50%;
  background:var(--sage); display:inline-block;
  animation:pulse-dot 2.2s infinite; flex-shrink:0;
}
.hero-wordmark {
  font-family:var(--playpen); font-weight:800;
  font-size:clamp(52px,12vw,96px); color:var(--brown);
  display:block; line-height:1; letter-spacing:-1px; margin-bottom:24px;
}
.hero h1 {
  font-weight:800; font-size:clamp(24px,5vw,48px);
  letter-spacing:-1.5px; line-height:1.1;
  color:var(--ink); margin-bottom:22px;
}
.hero h1 em {
  font-style:italic; font-family:var(--serif);
  font-weight:400; color:var(--brown);
}
.hero-tags {
  display:inline-flex; gap:8px; justify-content:center;
  flex-wrap:wrap; margin-bottom:14px;
}
.tag {
  border:1.5px solid var(--ink); border-radius:100px;
  padding:5px 16px; font-size:12.5px; font-weight:500; color:var(--ink);
}
.hero-sub { font-size:15px; color:var(--muted); margin-bottom:16px; }
.asso-pill {
  display:inline-flex; align-items:center; gap:6px;
  background:var(--sage-pale); border:1px solid rgba(110,126,100,.2);
  border-radius:100px; padding:5px 14px; margin-bottom:36px;
  font-size:11.5px; font-weight:500; color:var(--sage-bg);
}
.hero-actions {
  display:flex; align-items:center; justify-content:center;
  gap:12px; flex-wrap:wrap; margin-bottom:44px;
}
.btn-primary {
  display:inline-flex; align-items:center; gap:6px;
  background:var(--brown); color:#fff;
  font-size:14px; font-weight:700; text-decoration:none;
  padding:13px 28px; border-radius:7px; border:none; cursor:pointer;
  transition:background .15s, transform .12s; white-space:nowrap;
}
.btn-primary:hover { background:var(--brown-deep); transform:translateY(-1px); }
.btn-ghost-warm {
  display:inline-flex; align-items:center; gap:6px;
  background:var(--cream); color:var(--ink);
  font-size:14px; font-weight:500; text-decoration:none;
  padding:13px 28px; border-radius:7px; border:1px solid var(--border-2); cursor:pointer;
  transition:background .15s; white-space:nowrap;
}
.btn-ghost-warm:hover { background:var(--cream-2); }
.hero-proof {
  display:flex; align-items:center; justify-content:center;
  gap:14px; flex-wrap:wrap;
}
.av-stack { display:flex; }
.av {
  width:30px; height:30px; border-radius:50%;
  border:2px solid var(--parchment); background:var(--cream-2);
  margin-left:-8px; display:flex; align-items:center; justify-content:center;
  font-size:9px; font-weight:700; color:var(--muted);
}
.av:first-child { margin-left:0; }
.proof-txt { font-size:13px; color:var(--muted); }
.proof-txt strong { color:var(--ink); font-weight:600; }

/* ────────────────────────────────────────────
   STATS
──────────────────────────────────────────── */
.stats-strip {
  border-top:1px solid var(--border); border-bottom:1px solid var(--border);
  background:var(--cream); display:flex; flex-wrap:wrap; justify-content:center;
}
.stat-item {
  padding:24px 0; text-align:center;
  flex:1 1 25%; min-width:100px; border-right:1px solid var(--border);
}
.stat-item:last-child { border-right:none; }
.stat-n {
  display:block; font-size:30px; font-weight:800;
  letter-spacing:-1.5px; color:var(--ink); line-height:1; margin-bottom:4px;
}
.stat-l { font-size:12px; color:var(--muted); }

/* ────────────────────────────────────────────
   PROCHAINE TABLE
──────────────────────────────────────────── */
.section-next {
  background:var(--sage); padding:64px 24px;
  text-align:center; color:#fff;
}
.section-next h2 {
  font-weight:800; font-size:clamp(26px,5vw,36px);
  letter-spacing:-1px; margin-bottom:6px;
}
.next-sub { font-size:14px; opacity:.65; margin-bottom:36px; }
.countdown-row {
  display:inline-flex;
  background:rgba(0,0,0,.18); border:1px solid rgba(255,255,255,.12);
  border-radius:10px; overflow:hidden; margin-bottom:36px;
}
.cd-block {
  padding:20px 28px; border-right:1px solid rgba(255,255,255,.10);
  min-width:80px; text-align:center;
}
.cd-block:last-child { border-right:none; }
.cd-n {
  display:block; font-size:clamp(36px,8vw,50px); font-weight:800;
  letter-spacing:-2px; line-height:1; color:#fff;
  margin-bottom:6px; font-variant-numeric:tabular-nums;
}
.cd-l {
  display:block; font-size:10px; font-weight:700;
  letter-spacing:.14em; text-transform:uppercase; color:rgba(255,255,255,.4);
}
.spots-pill {
  display:inline-flex; align-items:center; gap:8px;
  background:rgba(255,255,255,.10); border:1px solid rgba(255,255,255,.18);
  border-radius:100px; padding:8px 20px;
  font-size:13px; font-weight:500; color:rgba(255,255,255,.85);
}

/* ────────────────────────────────────────────
   TICKER
──────────────────────────────────────────── */
.ticker-wrap {
  overflow:hidden; background:var(--cream-2);
  border-top:1px solid var(--border); border-bottom:1px solid var(--border);
  padding:12px 0;
}
.ticker-inner { display:flex; width:max-content; animation:ticker 30s linear infinite; }
.ticker-item {
  display:flex; align-items:center; gap:18px; padding:0 36px;
  font-size:11.5px; font-weight:700; letter-spacing:.08em;
  text-transform:uppercase; color:var(--muted); white-space:nowrap;
}
.tsep { width:4px; height:4px; border-radius:50%; background:var(--brown); opacity:.5; flex-shrink:0; }

/* ────────────────────────────────────────────
   EYEBROW
──────────────────────────────────────────── */
.eyebrow {
  font-size:11px; font-weight:700; letter-spacing:.12em;
  text-transform:uppercase; color:var(--brown); display:block; margin-bottom:14px;
}

/* ────────────────────────────────────────────
   FEATURES (POURQUOI)
──────────────────────────────────────────── */
.section-features { padding:80px 24px; max-width:1120px; margin:0 auto; }
.features-header { max-width:560px; margin-bottom:52px; }
.features-header h2 {
  font-weight:800; font-size:clamp(28px,5vw,42px);
  letter-spacing:-1.5px; line-height:1.08; margin-bottom:14px; color:var(--ink);
}
.features-header h2 em {
  font-style:italic; font-family:var(--serif); font-weight:400; color:var(--brown);
}
.features-header p { font-size:16px; color:var(--muted); line-height:1.75; }
.features-grid {
  display:grid; grid-template-columns:repeat(3,1fr);
  gap:1px; background:var(--border-2);
  border:1px solid var(--border-2); border-radius:10px; overflow:hidden;
}
.feat-card { background:var(--cream); padding:28px 24px; transition:background .2s; }
.feat-card:hover { background:var(--cream-2); }
.feat-label {
  font-size:11px; font-weight:700; letter-spacing:.10em;
  text-transform:uppercase; color:var(--brown); display:block; margin-bottom:10px;
}
.feat-card h3 { font-size:15px; font-weight:700; color:var(--ink); margin-bottom:8px; }
.feat-card p { font-size:13.5px; color:var(--muted); line-height:1.65; }

/* ────────────────────────────────────────────
   HOW IT WORKS
──────────────────────────────────────────── */
.section-how {
  padding:80px 24px; background:var(--cream-2);
  border-top:1px solid var(--border); border-bottom:1px solid var(--border);
}
.section-how-inner { max-width:1120px; margin:0 auto; }
.how-header { margin-bottom:52px; }
.how-header h2 {
  font-weight:800; font-size:clamp(28px,5vw,42px);
  letter-spacing:-1.5px; line-height:1.08; color:var(--ink);
}
.how-grid { display:grid; grid-template-columns:1fr 1fr; gap:64px; align-items:start; }
.how-steps { display:flex; flex-direction:column; }
.how-step { display:flex; gap:18px; padding:18px 0; border-bottom:1px solid var(--border); }
.how-step:first-child { border-top:1px solid var(--border); }
.step-num {
  width:28px; height:28px; border-radius:50%;
  background:var(--parchment); border:1.5px solid rgba(200,117,66,.35);
  display:flex; align-items:center; justify-content:center;
  flex-shrink:0; font-size:10px; font-weight:800; color:var(--brown); margin-top:2px;
}
.step-body strong { display:block; font-size:14px; font-weight:700; color:var(--ink); margin-bottom:3px; }
.step-body span { font-size:13.5px; color:var(--muted); line-height:1.55; }
.how-visual {
  background:var(--parchment); border:1px solid var(--border-2);
  border-radius:12px; padding:24px; position:sticky; top:78px;
}
.hv-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:20px; }
.hv-title { font-size:11px; font-weight:700; letter-spacing:.10em; text-transform:uppercase; color:var(--muted); }
.live-badge {
  display:inline-flex; align-items:center; gap:5px;
  background:var(--sage-pale); border:1px solid rgba(110,126,100,.2);
  border-radius:4px; padding:3px 10px;
  font-size:10.5px; font-weight:700; letter-spacing:.08em; text-transform:uppercase; color:var(--sage-bg);
}
.tc-list { display:flex; flex-direction:column; gap:8px; margin-bottom:16px; }
.tc {
  background:var(--cream); border:1px solid var(--border);
  border-radius:7px; padding:12px 14px;
  display:flex; align-items:center; justify-content:space-between; gap:10px;
}
.tc-l { display:flex; align-items:center; gap:10px; min-width:0; }
.avs { display:flex; flex-shrink:0; }
.mav {
  width:20px; height:20px; border-radius:50%;
  background:var(--cream-2); border:1.5px solid var(--cream);
  margin-left:-4px; display:flex; align-items:center; justify-content:center;
  font-size:7px; font-weight:700; color:var(--muted); flex-shrink:0;
}
.mav:first-child { margin-left:0; }
.tc-name { font-size:13px; font-weight:600; color:var(--ink); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.tc-s { font-size:10.5px; font-weight:700; border-radius:4px; padding:2px 8px; flex-shrink:0; }
.s-full { background:var(--cream-2); color:var(--muted); }
.s-open { background:var(--brown-pale); color:var(--brown-deep); border:1px solid rgba(200,117,66,.2); }
.hv-foot {
  font-size:11px; color:var(--muted-lt); text-align:center;
  padding-top:12px; border-top:1px solid var(--border); line-height:1.6;
}

/* ────────────────────────────────────────────
   CAROUSEL AVIS — style original de cheznola.fr
──────────────────────────────────────────── */
.section-avis { background:var(--sage); padding:72px 0; }
.section-avis-inner { max-width:1120px; margin:0 auto; padding:0 24px; }
.section-avis h2 {
  font-weight:800; font-size:clamp(26px,5vw,36px);
  letter-spacing:-1px; color:#fff; margin-bottom:44px;
}

#nolaTestimonial {
  position:relative; width:100%; max-width:100%;
  font-family:var(--sans);
}
#nolaTestimonial .nola-tc__inner {
  display:grid; grid-auto-flow:column; grid-auto-columns:88%;
  gap:18px; overflow-x:auto; overscroll-behavior-x:contain;
  scroll-snap-type:x mandatory; scroll-behavior:smooth;
  -webkit-overflow-scrolling:touch;
  padding:10px 64px 14px 6px;
}
#nolaTestimonial .nola-tc__inner::-webkit-scrollbar { height:8px; }
#nolaTestimonial .nola-tc__inner::-webkit-scrollbar-thumb { background:rgba(0,0,0,.14); border-radius:999px; }
#nolaTestimonial .nola-tc__inner::-webkit-scrollbar-track { background:rgba(255,255,255,.18); border-radius:999px; }
@media(min-width:760px)  { #nolaTestimonial .nola-tc__inner { grid-auto-columns:calc(50% - 9px); } }
@media(min-width:1024px) { #nolaTestimonial .nola-tc__inner { grid-auto-columns:calc(33.333% - 12px); } }
@media(min-width:1280px) { #nolaTestimonial .nola-tc__inner { grid-auto-columns:calc(25% - 14px); } }

#nolaTestimonial .nola-card {
  scroll-snap-align:start; border-radius:22px;
  background:#fff; border:1px solid rgba(0,0,0,.06);
  box-shadow:0 10px 30px rgba(0,0,0,.08); padding:18px 18px 16px;
}
#nolaTestimonial .nola-head { display:flex; gap:12px; align-items:flex-start; margin-bottom:12px; }
#nolaTestimonial .nola-avatarWrap { position:relative; width:48px; height:48px; flex:0 0 auto; }
#nolaTestimonial .nola-avatar { width:48px; height:48px; border-radius:999px; object-fit:cover; display:block; border:1px solid rgba(0,0,0,.08); }
#nolaTestimonial .nola-liBadge {
  position:absolute; right:-4px; bottom:-4px;
  width:22px; height:22px; border-radius:6px;
  background:#fff; padding:1.5px; border:2px solid rgba(255,255,255,.95);
  box-shadow:0 6px 14px rgba(0,0,0,.18);
  display:flex; align-items:center; justify-content:center;
}
#nolaTestimonial .nola-liBadge img { width:100%; height:100%; object-fit:contain; display:block; }
#nolaTestimonial .nola-meta { min-width:0; display:flex; flex-direction:column; gap:3px; }
#nolaTestimonial .nola-nameRow { display:flex; align-items:center; gap:6px; line-height:1.1; min-width:0; }
#nolaTestimonial .nola-name { font-weight:600; font-size:16px; color:rgba(0,0,0,.88); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
#nolaTestimonial .nola-verified { width:14px; height:14px; border-radius:999px; object-fit:cover; flex:0 0 auto; }
#nolaTestimonial .nola-role { font-size:14px; color:rgba(0,0,0,.58); line-height:1.15; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
#nolaTestimonial .nola-date { font-size:13px; color:rgba(0,0,0,.42); line-height:1.15; }
#nolaTestimonial .nola-quote { margin:0; font-size:15px; color:rgba(0,0,0,.80); line-height:1.5; }
#nolaTestimonial .nola-next {
  position:absolute; top:50%; right:8px; transform:translateY(-50%);
  width:44px; height:44px; border-radius:999px; border:0;
  background:rgba(0,0,0,.22); color:#fff;
  font-size:22px; cursor:pointer;
  display:flex; align-items:center; justify-content:center;
  backdrop-filter:blur(6px); z-index:5;
}
#nolaTestimonial .nola-next:disabled { opacity:.35; cursor:default; }
@media(max-width:420px) {
  #nolaTestimonial .nola-quote { font-size:14px; }
  #nolaTestimonial .nola-next { right:10px; width:42px; height:42px; }
}

/* ────────────────────────────────────────────
   NOLA ORIGINALS
──────────────────────────────────────────── */
.section-originals {
  padding:80px 24px; max-width:760px; margin:0 auto; text-align:center;
}
.orig-header { margin-bottom:32px; }
.orig-header h2 {
  font-family:var(--playpen); font-weight:800;
  font-size:clamp(32px,6vw,52px);
  color:var(--brown); margin-bottom:14px; line-height:1.1;
}
.orig-lead-bold { font-size:17px; font-weight:700; color:var(--ink); margin-bottom:6px; }
.orig-lead { font-size:15px; color:var(--muted); line-height:1.7; }
.orig-price {
  display:inline-block;
  background:var(--cream-2); border:1px solid var(--border-2);
  border-radius:8px; padding:10px 28px; margin-bottom:28px;
  font-size:26px; font-weight:800; letter-spacing:-1px; color:var(--ink);
}
.orig-feats {
  list-style:none; display:flex; flex-direction:column;
  margin-bottom:20px; text-align:left;
  max-width:400px; margin-left:auto; margin-right:auto;
}
.orig-feats li {
  display:flex; align-items:center; gap:12px;
  font-size:15px; font-weight:500; color:var(--ink);
  padding:10px 0; border-bottom:1px solid var(--border);
}
.orig-feats li:last-child { border-bottom:none; }
.orig-feats li::before { content:'✓'; color:var(--sage-bg); font-weight:800; font-size:14px; flex-shrink:0; }
.orig-notes { margin-bottom:32px; }
.orig-notes p {
  font-family:var(--serif); font-style:italic;
  font-size:14px; color:var(--muted-lt); line-height:1.65; margin-bottom:4px;
}

/* ────────────────────────────────────────────
   CONVERSATIONS
──────────────────────────────────────────── */
.section-conv {
  background:var(--cream-2); padding:80px 24px;
  border-top:1px solid var(--border); border-bottom:1px solid var(--border);
}
