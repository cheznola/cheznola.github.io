<script>
/* FAQ */
document.querySelectorAll('.faq-q').forEach(btn => {
  btn.addEventListener('click', () => {
    const item = btn.parentElement;
    const open = item.classList.contains('open');
    document.querySelectorAll('.faq-item.open').forEach(i => i.classList.remove('open'));
    if (!open) item.classList.add('open');
  });
});

/* Countdown — cible le prochain 2ᵉ mardi du mois à 19h30 */
function getNextTarget() {
  const now = new Date();
  const d = new Date(now.getFullYear(), now.getMonth(), 1);
  let count = 0;
  while (count < 2) { if (d.getDay() === 2) count++; if (count < 2) d.setDate(d.getDate() + 1); }
  d.setHours(19, 30, 0, 0);
  if (d <= now) {
    const next = new Date(now.getFullYear(), now.getMonth() + 1, 1);
    let c = 0;
    while (c < 2) { if (next.getDay() === 2) c++; if (c < 2) next.setDate(next.getDate() + 1); }
    next.setHours(19, 30, 0, 0);
    return next;
  }
  return d;
}
function tick() {
  const diff = Math.max(0, getNextTarget() - new Date());
  const pad = n => String(Math.floor(n)).padStart(2,'0');
  document.getElementById('cd-d').textContent = pad(diff / 86400000);
  document.getElementById('cd-h').textContent = pad((diff % 86400000) / 3600000);
  document.getElementById('cd-m').textContent = pad((diff % 3600000) / 60000);
  document.getElementById('cd-s').textContent = pad((diff % 60000) / 1000);
}
tick(); setInterval(tick, 1000);

/* Scroll reveal */
const io = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) { e.target.style.opacity='1'; e.target.style.transform='translateY(0)'; }
  });
}, { threshold: 0.06 });
document.querySelectorAll('.section-features, .section-how-inner, .section-originals, .conv-inner, .section-faq').forEach(el => {
  el.style.cssText += 'opacity:0;transform:translateY(18px);transition:opacity .65s ease,transform .65s ease;';
  io.observe(el);
});

/* Carousel */
(function () {
  const root    = document.getElementById('nolaTestimonial');
  if (!root) return;
  const track   = root.querySelector('.nola-tc__inner');
  const nextBtn = root.querySelector('.nola-next');

  const AVATAR   = 'https://res.cloudinary.com/dtjcum3gb/image/upload/v1765707220/Nola._2_kh6us9.png';
  const LINKEDIN = 'https://res.cloudinary.com/dtjcum3gb/image/upload/v1765707210/LinkedIn_logo_initials_i5mnfq.png';
  const VERIFIED = 'https://res.cloudinary.com/dtjcum3gb/image/upload/v1765707210/instagram-verification-badge_htnu2v.jpg';

  const REVIEWS = [
